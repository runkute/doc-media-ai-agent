# ── Anthropic Claude API ──────────────────────────────────────────
# Lấy tại: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here
# Thêm key thứ 2, 3... để round-robin tránh hết credit
# ANTHROPIC_API_KEY_2=sk-ant-api03-your_second_key_here
# ANTHROPIC_API_KEY_3=sk-ant-api03-your_third_key_here

# ── Google Gemini API ─────────────────────────────────────────────
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Thêm key thứ 2, 3... để round-robin tránh quota
# GEMINI_API_KEY_2=your_second_gemini_key_here
# GEMINI_API_KEY_3=your_third_gemini_key_here

# ── FAL.ai (Tạo ảnh) ─────────────────────────────────────────────
# Lấy tại: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# ── Facebook Ads API ──────────────────────────────────────────────
# Lấy tại: https://developers.facebook.com → Tools → Graph API Explorer
FB_ACCESS_TOKEN=your_facebook_access_token_here
# ID tài khoản quảng cáo (dạng: act_XXXXXXXXXX) — tùy chọn, app tự load từ API
FB_AD_ACCOUNT_ID=act_your_account_id_here
